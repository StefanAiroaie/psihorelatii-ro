---
const GTM_ID = "GTM-KKT24HL4";
const ADSENSE_CLIENT = "ca-pub-2362578685287844";
---

<!-- Google Consent Mode v2 — default denied BEFORE any tag loads -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  window.gtag = window.gtag || function(){ window.dataLayer.push(arguments); };
  window.gtag('consent', 'default', {
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    analytics_storage: 'denied',
    functionality_storage: 'denied',
    personalization_storage: 'denied',
    security_storage: 'granted',
    wait_for_update: 500
  });
  window.gtag('set', 'ads_data_redaction', true);
  window.gtag('set', 'url_passthrough', true);
</script>

<div class="cookie-banner" id="cookie-banner" hidden>
  <p>
    Folosim cookie-uri pentru a analiza traficul și pentru a afișa reclame relevante,
    doar cu acordul tău. Poți alege ce accepți.
  </p>

  <div class="cookie-toggles" id="cookie-toggles" hidden>
    <label class="cookie-toggle">
      <input type="checkbox" id="consent-analytics" checked />
      <span class="toggle-label">
        <strong>Statistice</strong>
        <small>Google Analytics — trafic anonim</small>
      </span>
    </label>
    <label class="cookie-toggle">
      <input type="checkbox" id="consent-marketing" checked />
      <span class="toggle-label">
        <strong>Marketing</strong>
        <small>Google Ads — reclame personalizate</small>
      </span>
    </label>
  </div>

  <div class="cookie-actions">
    <button type="button" id="cookie-accept">Accepta toate</button>
    <button type="button" id="cookie-choose" class="ghost">Alege</button>
    <button type="button" id="cookie-save" class="ghost" hidden>Salveaza alegerea</button>
    <button type="button" id="cookie-reject" class="ghost">Respinge</button>
  </div>

  <p class="cookie-links">
    <a href="/politica-cookie">Politica de cookie</a> ·
    <a href="/politica-confidentialitate">Confidentialitate</a>
  </p>
</div>

<button type="button" class="cookie-fab" id="cookie-fab" hidden aria-label="Setari cookie">
  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"/>
    <circle cx="8" cy="9" r="1.2" fill="currentColor" stroke="none"/>
    <circle cx="14" cy="7" r="1" fill="currentColor" stroke="none"/>
    <circle cx="16" cy="13" r="1.2" fill="currentColor" stroke="none"/>
    <circle cx="10" cy="14" r="1.4" fill="currentColor" stroke="none"/>
    <circle cx="6" cy="13" r="0.8" fill="currentColor" stroke="none"/>
    <circle cx="13" cy="17" r="1" fill="currentColor" stroke="none"/>
  </svg>
</button>

<script is:inline define:vars={{ GTM_ID, ADSENSE_CLIENT }}>
  (function() {
    var CONSENT_VERSION = '2.0';
    var CONSENT_MAX_AGE_DAYS = 365;
    var KEYS = {
      analytics: 'consent_analytics',
      marketing: 'consent_marketing',
      version:   'consent_version',
      ts:        'consent_ts'
    };

    function sGet(k) { try { return localStorage.getItem(k); } catch(e) { return null; } }
    function sSet(k, v) { try { localStorage.setItem(k, v); } catch(e) {} }
    function sRemove(k) { try { localStorage.removeItem(k); } catch(e) {} }

    var banner    = document.getElementById('cookie-banner');
    var toggles   = document.getElementById('cookie-toggles');
    var fab       = document.getElementById('cookie-fab');
    var acceptBtn = document.getElementById('cookie-accept');
    var chooseBtn = document.getElementById('cookie-choose');
    var saveBtn   = document.getElementById('cookie-save');
    var rejectBtn = document.getElementById('cookie-reject');
    var chkAnalyt = document.getElementById('consent-analytics');
    var chkMarket = document.getElementById('consent-marketing');
    var servicesLoaded = false;

    function expired(ts) {
      if (!ts) return true;
      return (Date.now() - Number(ts)) / 86400000 > CONSENT_MAX_AGE_DAYS;
    }

    /* ---- Consent Mode v2 update ---- */
    function pushConsent(analytics, marketing) {
      var aVal = analytics ? 'granted' : 'denied';
      var mVal = marketing ? 'granted' : 'denied';

      window.gtag('consent', 'update', {
        analytics_storage:       aVal,
        functionality_storage:   aVal,
        personalization_storage: aVal,
        ad_storage:              mVal,
        ad_user_data:            mVal,
        ad_personalization:      mVal
      });

      /* turn off redaction when ads are granted */
      if (marketing) {
        window.gtag('set', 'ads_data_redaction', false);
      }

      window.dataLayer.push({
        event: 'consent_update',
        consent_analytics: analytics,
        consent_marketing: marketing
      });
    }

    /* ---- Load GTM + AdSense ---- */
    function loadScript(src, attrs) {
      var s = document.createElement('script');
      s.src = src; s.async = true;
      if (attrs) { for (var k in attrs) s.setAttribute(k, attrs[k]); }
      document.head.appendChild(s);
    }

    function loadServices() {
      if (servicesLoaded) return;
      servicesLoaded = true;
      /* GTM */
      window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
      loadScript('https://www.googletagmanager.com/gtm.js?id=' + GTM_ID);
      /* AdSense */
      loadScript('https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=' + ADSENSE_CLIENT, {
        crossorigin: 'anonymous'
      });
    }

    /* ---- Persist ---- */
    function persist(analytics, marketing) {
      sSet(KEYS.analytics, analytics ? '1' : '0');
      sSet(KEYS.marketing, marketing ? '1' : '0');
      sSet(KEYS.version, CONSENT_VERSION);
      sSet(KEYS.ts, String(Date.now()));
    }

    /* ---- UI helpers ---- */
    function showBanner() {
      if (banner) banner.removeAttribute('hidden');
      if (fab) fab.setAttribute('hidden', '');
    }
    function hideBanner() {
      if (banner) banner.setAttribute('hidden', '');
      if (fab) fab.removeAttribute('hidden');
    }

    /* ---- Actions ---- */
    function acceptAll() {
      persist(true, true);
      pushConsent(true, true);
      loadServices();
      hideBanner();
    }

    function saveChoices() {
      var a = chkAnalyt && chkAnalyt.checked;
      var m = chkMarket && chkMarket.checked;
      persist(a, m);
      pushConsent(a, m);
      if (a || m) loadServices();
      hideBanner();
    }

    function rejectAll() {
      persist(false, false);
      pushConsent(false, false);
      hideBanner();
    }

    function showChoices() {
      if (toggles) toggles.removeAttribute('hidden');
      if (chooseBtn) chooseBtn.setAttribute('hidden', '');
      if (saveBtn) saveBtn.removeAttribute('hidden');
    }

    function reopen() {
      for (var k in KEYS) sRemove(KEYS[k]);
      if (toggles) toggles.setAttribute('hidden', '');
      if (chooseBtn) chooseBtn.removeAttribute('hidden');
      if (saveBtn) saveBtn.setAttribute('hidden', '');
      if (chkAnalyt) chkAnalyt.checked = true;
      if (chkMarket) chkMarket.checked = true;
      showBanner();
    }

    /* ---- Init ---- */
    var ver = sGet(KEYS.version);
    var ts  = sGet(KEYS.ts);
    var valid = ver === CONSENT_VERSION && !expired(ts) && sGet(KEYS.analytics) !== null;

    if (!valid) {
      /* migrate from v1 keys */
      sRemove('cookiesAccepted');
      sRemove('cookiesVersion');
      sRemove('cookiesTimestamp');
      showBanner();
    } else {
      var a = sGet(KEYS.analytics) === '1';
      var m = sGet(KEYS.marketing) === '1';
      pushConsent(a, m);
      if (a || m) loadServices();
      hideBanner();
    }

    /* ---- Bind ---- */
    if (acceptBtn) acceptBtn.addEventListener('click', acceptAll);
    if (chooseBtn) chooseBtn.addEventListener('click', showChoices);
    if (saveBtn)   saveBtn.addEventListener('click', saveChoices);
    if (rejectBtn) rejectBtn.addEventListener('click', rejectAll);
    if (fab)       fab.addEventListener('click', reopen);
  })();
</script>

<style>
  .cookie-banner[hidden],
  .cookie-fab[hidden] {
    display: none !important;
  }

  .cookie-banner {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    width: min(30rem, calc(100vw - 2rem));
    display: grid;
    gap: 0.75rem;
    padding: 1.15rem 1.25rem 1.1rem;
    border-radius: 18px;
    border: 1px solid rgba(35, 56, 44, 0.12);
    background: rgba(255, 252, 247, 0.98);
    box-shadow: 0 22px 48px rgba(45, 42, 33, 0.18);
    backdrop-filter: blur(10px);
  }

  .cookie-banner p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
    font-size: 0.92rem;
  }

  .cookie-links {
    font-size: 0.82rem !important;
  }

  .cookie-banner a {
    color: var(--accent-deep);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  /* --- Granular toggles --- */
  .cookie-toggles[hidden] { display: none !important; }

  .cookie-toggles {
    display: grid;
    gap: 0.55rem;
  }

  .cookie-toggle {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    cursor: pointer;
    padding: 0.5rem 0.65rem;
    border-radius: 10px;
    background: rgba(35, 56, 44, 0.04);
    transition: background 0.15s ease;
  }

  .cookie-toggle:hover {
    background: rgba(35, 56, 44, 0.08);
  }

  .cookie-toggle input[type="checkbox"] {
    margin-top: 0.2rem;
    width: 1.1rem;
    height: 1.1rem;
    accent-color: var(--forest);
    cursor: pointer;
    flex-shrink: 0;
  }

  .toggle-label {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .toggle-label strong {
    font-size: 0.9rem;
    color: var(--forest);
  }

  .toggle-label small {
    font-size: 0.78rem;
    color: var(--muted);
  }

  /* --- Buttons --- */
  .cookie-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .cookie-actions button {
    border: 0;
    cursor: pointer;
    font: inherit;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: var(--forest);
    color: #fff;
    font-weight: 800;
    font-size: 0.88rem;
    transition: opacity 0.15s ease;
  }

  .cookie-actions button:hover {
    opacity: 0.88;
  }

  .cookie-actions button[hidden] {
    display: none !important;
  }

  .cookie-actions .ghost {
    background: rgba(35, 56, 44, 0.08);
    color: var(--forest);
  }

  /* --- FAB --- */
  .cookie-fab {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 55;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(35, 56, 44, 0.12);
    border-radius: 50%;
    background: rgba(255, 252, 247, 0.96);
    color: var(--forest);
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(45, 42, 33, 0.15);
    backdrop-filter: blur(10px);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .cookie-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 10px 28px rgba(45, 42, 33, 0.22);
  }

  @media (max-width: 720px) {
    .cookie-banner {
      left: 0.75rem;
      right: 0.75rem;
      width: auto;
      bottom: 0.75rem;
    }
    .cookie-fab {
      right: 0.75rem;
      bottom: 0.75rem;
    }
  }
</style>
