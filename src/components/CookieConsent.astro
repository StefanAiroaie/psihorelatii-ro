---
const GTM_ID = "GTM-KKT24HL4";
const ADSENSE_CLIENT = "ca-pub-2362578685287844";
---

<>
  <script is:inline>
    {`
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function(){ window.dataLayer.push(arguments); };
      window.gtag('consent', 'default', {
        ad_storage: 'denied',
        analytics_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied'
      });
    `}
  </script>

  <div class="cookie-banner" id="cookie-banner" hidden>
    <p>
      Folosim cookie-uri pentru masurarea traficului si pentru reclame Google doar dupa
      consimtamant. Detalii in <a href="/politica-cookie">Politica de cookie</a> si
      <a href="/politica-confidentialitate">Politica de confidentialitate</a>.
    </p>
    <div class="cookie-actions">
      <button type="button" data-consent-action="accept">Accepta toate</button>
      <button type="button" data-consent-action="reject" class="ghost">Respinge</button>
    </div>
  </div>

  <button type="button" class="cookie-settings" id="cookie-settings" hidden>
    Setari cookie
  </button>

  <script is:inline define:vars={{ GTM_ID, ADSENSE_CLIENT }}>
    {`
      const CONSENT_VERSION = '1.0';
      const CONSENT_MAX_AGE_DAYS = 365;
      const STORAGE_KEYS = {
        accepted: 'cookiesAccepted',
        version: 'cookiesVersion',
        ts: 'cookiesTimestamp'
      };

      const safeStorage = {
        get(key) {
          try { return window.localStorage.getItem(key); } catch { return null; }
        },
        set(key, value) {
          try { window.localStorage.setItem(key, value); } catch {}
        },
        remove(key) {
          try { window.localStorage.removeItem(key); } catch {}
        }
      };

      const banner = document.getElementById('cookie-banner');
      const settingsButton = document.getElementById('cookie-settings');
      let loadedServices = false;

      function consentExpired(ts) {
        if (!ts) return true;
        const days = (Date.now() - Number(ts)) / (1000 * 60 * 60 * 24);
        return days > CONSENT_MAX_AGE_DAYS;
      }

      function updateConsent(state) {
        const value = state ? 'granted' : 'denied';
        window.gtag('consent', 'update', {
          ad_storage: value,
          analytics_storage: value,
          ad_user_data: value,
          ad_personalization: value
        });
        window.dataLayer.push({ event: 'cookie_consent_updated', cookiesAccepted: state });
      }

      function loadScript(src, attrs = {}) {
        const script = document.createElement('script');
        script.src = src;
        script.async = true;
        Object.entries(attrs).forEach(([key, value]) => script.setAttribute(key, value));
        document.head.appendChild(script);
      }

      function loadServices() {
        if (loadedServices) return;
        loadedServices = true;
        loadScript('https://www.googletagmanager.com/gtm.js?id=' + GTM_ID);
        loadScript('https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=' + ADSENSE_CLIENT, {
          crossorigin: 'anonymous'
        });
      }

      function persistDecision(accepted) {
        safeStorage.set(STORAGE_KEYS.accepted, accepted ? 'true' : 'false');
        safeStorage.set(STORAGE_KEYS.version, CONSENT_VERSION);
        safeStorage.set(STORAGE_KEYS.ts, String(Date.now()));
      }

      function showBanner() {
        banner?.removeAttribute('hidden');
        settingsButton?.removeAttribute('hidden');
      }

      function hideBanner() {
        banner?.setAttribute('hidden', '');
        settingsButton?.removeAttribute('hidden');
      }

      function acceptCookies() {
        persistDecision(true);
        updateConsent(true);
        loadServices();
        hideBanner();
      }

      function rejectCookies() {
        persistDecision(false);
        updateConsent(false);
        hideBanner();
      }

      function reopenPreferences() {
        safeStorage.remove(STORAGE_KEYS.accepted);
        safeStorage.remove(STORAGE_KEYS.version);
        safeStorage.remove(STORAGE_KEYS.ts);
        showBanner();
      }

      const storedConsent = safeStorage.get(STORAGE_KEYS.accepted);
      const storedVersion = safeStorage.get(STORAGE_KEYS.version);
      const storedTs = safeStorage.get(STORAGE_KEYS.ts);
      const validConsent =
        storedConsent !== null &&
        storedVersion === CONSENT_VERSION &&
        !consentExpired(storedTs);

      if (!validConsent) {
        showBanner();
      } else if (storedConsent === 'true') {
        updateConsent(true);
        loadServices();
        hideBanner();
      } else {
        updateConsent(false);
        hideBanner();
      }

      banner?.querySelector('[data-consent-action="accept"]')?.addEventListener('click', acceptCookies);
      banner?.querySelector('[data-consent-action="reject"]')?.addEventListener('click', rejectCookies);
      settingsButton?.addEventListener('click', reopenPreferences);
    `}
  </script>
</>

<style>
  .cookie-banner {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    width: min(28rem, calc(100vw - 2rem));
    display: grid;
    gap: 0.9rem;
    padding: 1rem 1rem 1.05rem;
    border-radius: 18px;
    border: 1px solid rgba(35, 56, 44, 0.12);
    background: rgba(255, 252, 247, 0.98);
    box-shadow: 0 22px 48px rgba(45, 42, 33, 0.18);
  }

  .cookie-banner p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .cookie-banner a {
    color: var(--accent-deep);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cookie-actions button,
  .cookie-settings {
    border: 0;
    cursor: pointer;
    font: inherit;
  }

  .cookie-actions button {
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: var(--forest);
    color: #fff;
    font-weight: 800;
  }

  .cookie-actions .ghost {
    background: rgba(35, 56, 44, 0.08);
    color: var(--forest);
  }

  .cookie-settings {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 55;
    padding: 0.7rem 0.95rem;
    border-radius: 999px;
    background: rgba(35, 56, 44, 0.92);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 14px 30px rgba(45, 42, 33, 0.18);
  }

  @media (max-width: 720px) {
    .cookie-banner {
      left: 0.75rem;
      right: 0.75rem;
      width: auto;
      bottom: 0.75rem;
    }
  }
</style>
