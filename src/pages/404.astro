---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Pagina nu a fost găsită — Psihorelatii.ro"
  description="Pagina pe care o cauți nu există sau a fost mutată."
  pathname="/404"
>
  <section class="shell not-found">
    <div class="not-found-inner card">
      <p class="eyebrow">Eroare 404</p>
      <h1>Pagina nu a fost găsită</h1>
      <p class="not-found-text">
        Pagina pe care o cauți nu există, a fost mutată sau adresa conține o greșeală.
      </p>
      <a href="/" class="not-found-link">Înapoi la pagina principală</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: grid;
    place-items: center;
    min-height: 60vh;
    padding: 2rem 0;
  }

  .not-found-inner {
    max-width: 36rem;
    padding: 2.5rem;
    text-align: center;
    display: grid;
    gap: 1rem;
    justify-items: center;
  }

  .not-found h1 {
    margin: 0;
    font-family: "Fraunces", serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    color: var(--forest);
  }

  .not-found-text {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .not-found-link {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.8rem 1.4rem;
    border-radius: 999px;
    background: var(--forest);
    color: #fff;
    font-weight: 800;
  }
</style>
