{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["astro/client", "node"]
  },
  "include": ["src/**/*", "astro.config.mjs"],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
